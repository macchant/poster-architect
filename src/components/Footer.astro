---
const currentYear = new Date().getFullYear();

const links = {
  navigasi: [
    { name: "Beranda", href: "/" },
    { name: "Katalog Buku", href: "/katalog" },
    { name: "Sumber Daya", href: "/sumber-daya" },
    { name: "Tentang Kami", href: "/tentang" },
  ],
  kategori: [
    { name: "Pengembangan Diri", href: "/katalog?kategori=pengembangan-diri" },
    { name: "Keterampilan Kerja", href: "/katalog?kategori=keterampilan" },
    { name: "Hukum & Hak", href: "/katalog?kategori=hukum" },
    { name: "Kesehatan Mental", href: "/katalog?kategori=kesehatan" },
    { name: "Wirausaha", href: "/katalog?kategori=wirausaha" },
  ],
  legal: [
    { name: "Kebijakan Privasi", href: "/privasi" },
    { name: "Syarat Penggunaan", href: "/syarat" },
  ]
};

const social = [
  { icon: "fa-instagram", href: "#", label: "Instagram" },
  { icon: "fa-tiktok", href: "#", label: "TikTok" },
  { icon: "fa-youtube", href: "#", label: "YouTube" },
];
---

<footer class="bg-gray-900 text-white relative overflow-hidden">
  <!-- Decorative background -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute top-0 right-0 w-96 h-96 bg-brand-500 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-forest-500 rounded-full blur-3xl translate-y-1/2 -translate-x-1/3"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 pt-20 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 pb-16 border-b border-white/10">

      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-brand-500 to-forest-500 rounded-xl flex items-center justify-center">
            <i class="fas fa-door-open text-white text-lg"></i>
          </div>
          <div>
            <span class="font-extrabold text-xl text-white leading-none">Buka<span class="text-brand-400">Pintu</span></span>
            <span class="block text-[10px] text-gray-400 tracking-wide uppercase">Perpustakaan Digital</span>
          </div>
        </a>
        <p class="text-gray-400 leading-relaxed mb-6 text-sm">
          Perpustakaan digital gratis yang menghubungkan mantan narapidana dengan pengetahuan, keterampilan, dan kesempatan untuk memulai ulang.
        </p>
        <div class="flex gap-3">
          {social.map((s) => (
            <a href={s.href} aria-label={s.label}
               class="w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center hover:bg-brand-600 transition-all hover:scale-110 text-sm">
              <i class={`fab ${s.icon}`}></i>
            </a>
          ))}
        </div>
      </div>

      <!-- Navigasi -->
      <div>
        <h4 class="font-bold text-sm uppercase tracking-wider text-gray-400 mb-5 flex items-center gap-2">
          <span class="w-5 h-0.5 bg-brand-500 rounded"></span>
          Navigasi
        </h4>
        <ul class="space-y-2.5">
          {links.navigasi.map((item) => (
            <li>
              <a href={item.href} class="text-gray-400 hover:text-brand-400 transition text-sm flex items-center gap-2 group">
                <i class="fas fa-chevron-right text-[10px] text-brand-600 group-hover:translate-x-1 transition-transform"></i>
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Kategori -->
      <div>
        <h4 class="font-bold text-sm uppercase tracking-wider text-gray-400 mb-5 flex items-center gap-2">
          <span class="w-5 h-0.5 bg-forest-500 rounded"></span>
          Kategori
        </h4>
        <ul class="space-y-2.5">
          {links.kategori.map((item) => (
            <li>
              <a href={item.href} class="text-gray-400 hover:text-forest-400 transition text-sm flex items-center gap-2 group">
                <i class="fas fa-chevron-right text-[10px] text-forest-600 group-hover:translate-x-1 transition-transform"></i>
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Admin -->
      <div>
        <h4 class="font-bold text-sm uppercase tracking-wider text-gray-400 mb-5 flex items-center gap-2">
          <span class="w-5 h-0.5 bg-warm-400 rounded"></span>
          Kelola
        </h4>
        <a href="/admin" class="inline-flex items-center gap-2 px-5 py-2.5 bg-gray-700 text-white text-sm font-semibold rounded-full hover:bg-gray-600 transition-all hover:-translate-y-0.5 shadow-lg shadow-gray-900/30 mb-4">
          <i class="fas fa-cog"></i>
          Panel Admin
        </a>
        <div class="bg-white/5 rounded-xl p-4">
          <p class="text-xs text-gray-500 mb-1">Jl. Sudirman No. 1, Jakarta</p>
          <p class="text-xs text-gray-500">info@bukapintu.org</p>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-sm text-center md:text-left">
        &copy; {currentYear} Buka Pintu. Dibuat dengan <i class="fas fa-heart text-brand-500"></i> untuk Indonesia.
      </p>
      <div class="flex gap-5 text-sm">
        {links.legal.map((item) => (
          <a href={item.href} class="text-gray-500 hover:text-brand-400 transition">{item.name}</a>
        ))}
      </div>
    </div>
  </div>
</footer>