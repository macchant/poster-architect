---
const navLinks = [
  { name: "Beranda", href: "/" },
  { name: "Katalog", href: "/katalog" },
  { name: "Sumber Daya", href: "/sumber-daya" },
  { name: "Tentang", href: "/tentang" },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white/90 backdrop-blur-md border-b border-brand-100/50">
  <div class="max-w-7xl mx-auto px-6 py-4">
    <div class="flex items-center justify-between">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-11 h-11 bg-gradient-to-br from-brand-500 to-forest-500 rounded-xl flex items-center justify-center shadow-md group-hover:scale-105 transition-transform">
          <i class="fas fa-door-open text-white text-lg"></i>
        </div>
        <div>
          <span class="font-extrabold text-xl text-gray-900 leading-none">Buka<span class="text-brand-600">Pintu</span></span>
          <span class="block text-[10px] text-gray-500 font-medium tracking-wide uppercase mt-0.5">Perpustakaan Digital</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-2">
        {navLinks.map((link) => (
          <a href={link.href}
             class="px-4 py-2 rounded-full text-sm font-medium text-gray-600 hover:text-brand-700 hover:bg-brand-50 transition-all">
            {link.name}
          </a>
        ))}
      </div>

      <!-- Right Actions -->
      <div class="flex items-center gap-3">
        <a href="/katalog" class="hidden md:inline-flex btn-primary text-sm">
          <i class="fas fa-search"></i>
          Cari Buku
        </a>
        <a href="/admin"
           class="w-10 h-10 rounded-full bg-gray-800 text-white flex items-center justify-center hover:bg-gray-900 transition-all hover:scale-110 shadow-sm"
           aria-label="Panel Admin">
          <i class="fas fa-cog text-sm"></i>
        </a>
        <button id="mobile-menu-btn"
          class="md:hidden w-10 h-10 flex items-center justify-center rounded-xl hover:bg-brand-50 transition text-gray-700"
          aria-label="Menu">
          <i class="fas fa-bars text-lg"></i>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="md:hidden hidden mt-4 pt-4 border-t border-brand-100">
      <div class="flex flex-col gap-1 pb-2">
        {navLinks.map((link) => (
          <a href={link.href}
             class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 hover:text-brand-700 hover:bg-brand-50 font-medium transition">
            <i class="fas fa-link text-brand-400 w-5 text-center"></i>
            {link.name}
          </a>
        ))}
        <a href="/admin"
           class="flex items-center gap-3 px-4 py-3 rounded-xl text-gray-700 bg-gray-100 font-semibold mt-2">
          <i class="fas fa-cog text-gray-600 w-5 text-center"></i>
          Panel Admin
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const navbar = document.getElementById('navbar');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    const icon = mobileMenuBtn.querySelector('i');
    if (icon) {
      icon.classList.toggle('fa-bars');
      icon.classList.toggle('fa-times');
    }
  });

  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('shadow-lg', window.scrollY > 20);
  });
</script>