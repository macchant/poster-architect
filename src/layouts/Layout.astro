---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Buka Pintu — Perpustakaan digital gratis untuk mantan narapidana Indonesia. Akses buku, panduan keterampilan, dan sumber belajar tanpa biaya.",
  image = "/og-image.jpg"
} = Astro.props;

const fullTitle = title === "Beranda" ? "Buka Pintu — Perpustakaan Digital Gratis" : `${title} | Buka Pintu`;
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Buka Pintu" />
  <meta name="theme-color" content="#EA580C" />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>

<body class="bg-warm-50 text-gray-900 antialiased">
  <Navbar />

  <main class="pt-20">
    <slot />
  </main>

  <Footer />

  <!-- Back to top -->
  <button id="back-to-top"
    class="fixed bottom-8 right-8 w-12 h-12 bg-brand-600 text-white rounded-full shadow-lg
           flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300
           hover:bg-brand-700 hover:scale-110 z-40"
    aria-label="Kembali ke atas">
    <i class="fas fa-arrow-up"></i>
  </button>

  <script>
    const btn = document.getElementById('back-to-top');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        btn?.classList.remove('opacity-0', 'pointer-events-none');
        btn?.classList.add('opacity-100');
      } else {
        btn?.classList.add('opacity-0', 'pointer-events-none');
        btn?.classList.remove('opacity-100');
      }
    });
    btn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  </script>
</body>
</html>