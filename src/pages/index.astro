---
import Layout from '../layouts/Layout.astro';

const featuredBooks = [
  {
    title: 'Belajar dari Kegagalan: Kisah 100 Pengusaha Sukses',
    author: 'Budi Santoso',
    year: '2022',
    category: 'Kisah Inspiratif',
    colorFrom: 'from-amber-500',
    colorTo: 'to-orange-600',
    pages: 212,
  },
  {
    title: 'Panduan Hukum bagi Masyarakat Indonesia',
    author: 'Dr. Rina Marlina, S.H., M.H.',
    year: '2021',
    category: 'Hukum & Hak',
    colorFrom: 'from-emerald-500',
    colorTo: 'to-teal-600',
    pages: 180,
  },
  {
    title: 'Membangun Mental Baja: Bangkit dari Keterpurukan',
    author: 'Ahmad Fauzi',
    year: '2020',
    category: 'Pengembangan Diri',
    colorFrom: 'from-blue-500',
    colorTo: 'to-cyan-600',
    pages: 198,
  },
  {
    title: 'Keterampilan Las & Kerja Logam untuk UMKM',
    author: 'Ir. Hendra Wijaya',
    year: '2023',
    category: 'Keterampilan Kerja',
    colorFrom: 'from-violet-500',
    colorTo: 'to-purple-600',
    pages: 156,
  },
  {
    title: 'Dasar-Dasar Akuntansi untuk Pelaku UMKM',
    author: 'Dewi Kusuma, S.E.',
    year: '2022',
    category: 'Wirausaha',
    colorFrom: 'from-rose-500',
    colorTo: 'to-pink-600',
    pages: 224,
  },
  {
    title: 'Hidup Sehat dengan Pola Makan Sederhana',
    author: 'dr. Santi Rahayu',
    year: '2021',
    category: 'Kesehatan Mental',
    colorFrom: 'from-sky-500',
    colorTo: 'to-blue-600',
    pages: 142,
  },
  {
    title: 'Belajar Bahasa Inggris dari Nol tanpa Guru',
    author: 'Michael Chen',
    year: '2023',
    category: 'Pendidikan',
    colorFrom: 'from-lime-500',
    colorTo: 'to-green-600',
    pages: 178,
  },
  {
    title: 'Wirausaha dari Garasi: Kisah Nyata Anak Bangsa',
    author: 'Tim Buka Pintu',
    year: '2024',
    category: 'Kisah Inspiratif',
    colorFrom: 'from-orange-500',
    colorTo: 'to-red-600',
    pages: 200,
  },
];

const stats = [
  { value: '2.500+', label: 'Judul Buku', icon: 'fa-book' },
  { value: '1.200+', label: 'Pengguna Aktif', icon: 'fa-users' },
  { value: '50+', label: 'Organisasi Partner', icon: 'fa-handshake' },
  { value: '100%', label: 'Gratis & Terbuka', icon: 'fa-unlock' },
];

const steps = [
  { num: '01', title: 'Cari Buku', desc: 'Temukan ribuan buku gratis dari berbagai kategori.', icon: 'fa-search' },
  { num: '02', title: 'Baca Online', desc: 'Buka dan baca langsung di browser tanpa perlu mengunduh.', icon: 'fa-laptop' },
  { num: '03', title: 'Unduh PDF', desc: 'Simpan ke Google Drive Anda untuk dibaca kapan saja.', icon: 'fa-download' },
];

const categories = [
  { name: 'Pengembangan Diri', count: 420, icon: 'fa-brain', color: 'bg-amber-100 text-amber-700', href: '/katalog' },
  { name: 'Keterampilan Kerja', count: 318, icon: 'fa-tools', color: 'bg-blue-100 text-blue-700', href: '/katalog' },
  { name: 'Hukum & Hak', count: 256, icon: 'fa-gavel', color: 'bg-emerald-100 text-emerald-700', href: '/katalog' },
  { name: 'Kesehatan Mental', count: 189, icon: 'fa-heart', color: 'bg-rose-100 text-rose-700', href: '/katalog' },
  { name: 'Wirausaha', count: 302, icon: 'fa-rocket', color: 'bg-violet-100 text-violet-700', href: '/katalog' },
  { name: 'Pendidikan', count: 445, icon: 'fa-graduation-cap', color: 'bg-sky-100 text-sky-700', href: '/katalog' },
];

const testimonials = [
  {
    quote: 'Buka Pintu membantu saya belajar manajemen bisnis saat di LP. Sekarang saya punya warung sendiri dan sudah punya 3 karyawan.',
    name: 'Hendra Pratama',
    role: 'Mantan Narapidana, kini Pemilik Warung',
    location: 'Jawa Barat',
    initials: 'HP',
    gradient: 'from-amber-400 to-orange-500',
  },
  {
    quote: 'Saya tidak punya uang untuk kursus bahasa Inggris. Melalui Buka Pintu, saya bisa belajar sendiri dan sekarang sudah lancar bekerja di hotel.',
    name: 'Siti Aminah',
    role: 'Mantan Narapidana, kini Staff Hotel',
    location: 'Surabaya',
    initials: 'SA',
    gradient: 'from-blue-400 to-cyan-500',
  },
  {
    quote: 'Buku hukum di Buka Pintu membantu saya memahami hak-hak saya saat masa tahanan. Pengetahuan itu sangat berharga.',
    name: 'Ahmad Fauzi',
    role: 'Mantan Narapidana, Aktivis Sosial',
    location: 'Yogyakarta',
    initials: 'AF',
    gradient: 'from-emerald-400 to-teal-500',
  },
];
---

<Layout title="Beranda">

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center overflow-hidden bg-warm-50">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-[700px] h-[700px] bg-gradient-to-br from-orange-100/60 to-amber-50/40 rounded-full blur-3xl"></div>
      <div class="absolute top-1/2 -left-60 w-[600px] h-[600px] bg-gradient-to-tr from-green-100/50 to-emerald-50/30 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-6 py-24 lg:py-0 lg:min-h-screen flex items-center w-full">
      <div class="grid lg:grid-cols-2 gap-12 items-center w-full">

        <!-- Text -->
        <div class="space-y-8">
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-orange-50 border border-orange-200 rounded-full text-sm font-semibold text-orange-700">
            <i class="fas fa-sparkles"></i>
            100% Gratis & Terbuka untuk Semua
          </div>

          <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold leading-[1.05] text-gray-900">
            Setiap Pintu<br>
            <span class="bg-gradient-to-r from-orange-500 via-orange-400 to-green-500 bg-clip-text text-transparent">Terbuka</span><br>
            untuk Anda
          </h1>

          <p class="text-lg md:text-xl text-gray-600 max-w-lg leading-relaxed">
            Perpustakaan digital gratis yang dirancang khusus untuk membantu mantan narapidana Indonesia membangun kembali hidup melalui pengetahuan dan keterampilan.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/katalog" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-orange-500 to-green-600 text-white font-bold rounded-full hover:shadow-xl hover:shadow-orange-500/25 transition-all hover:-translate-y-0.5 text-base">
              <i class="fas fa-book-open"></i>
              Jelajahi Katalog
            </a>
            <a href="/tentang" class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-orange-200 text-orange-700 font-bold rounded-full hover:bg-orange-50 transition-all text-base">
              <i class="fas fa-info-circle"></i>
              Pelajari Lebih
            </a>
          </div>

          <div class="flex flex-wrap gap-6 pt-2">
            <span class="flex items-center gap-2 text-sm text-gray-500 font-medium">
              <i class="fas fa-shield-alt text-green-600"></i>
              Tanpa biaya tersembunyi
            </span>
            <span class="flex items-center gap-2 text-sm text-gray-500 font-medium">
              <i class="fas fa-globe text-orange-600"></i>
              Akses di mana saja
            </span>
            <span class="flex items-center gap-2 text-sm text-gray-500 font-medium">
              <i class="fas fa-mobile-alt text-blue-600"></i>
              Mobile-friendly
            </span>
          </div>
        </div>

        <!-- Visual -->
        <div class="hidden lg:flex justify-center items-center relative">
          <div class="relative z-10 grid grid-cols-2 gap-4">
            <div class="space-y-4">
              <div class="bg-white rounded-2xl p-5 shadow-xl shadow-orange-500/10 border border-orange-50 transform -rotate-2 hover:rotate-0 transition-transform cursor-pointer">
                <div class="h-24 bg-gradient-to-br from-amber-400 to-orange-500 rounded-xl mb-3 flex items-center justify-center">
                  <i class="fas fa-brain text-white text-3xl"></i>
                </div>
                <p class="font-bold text-sm text-gray-900">Pengembangan Diri</p>
                <p class="text-xs text-gray-500 mt-1">420+ judul buku</p>
              </div>
              <div class="bg-white rounded-2xl p-5 shadow-xl shadow-green-500/10 border border-green-50 transform rotate-1 hover:rotate-0 transition-transform cursor-pointer">
                <div class="h-24 bg-gradient-to-br from-blue-500 to-cyan-500 rounded-xl mb-3 flex items-center justify-center">
                  <i class="fas fa-tools text-white text-3xl"></i>
                </div>
                <p class="font-bold text-sm text-gray-900">Keterampilan</p>
                <p class="text-xs text-gray-500 mt-1">318+ judul buku</p>
              </div>
            </div>
            <div class="space-y-4 mt-8">
              <div class="bg-white rounded-2xl p-5 shadow-xl shadow-blue-500/10 border border-blue-50 transform rotate-2 hover:rotate-0 transition-transform cursor-pointer">
                <div class="h-24 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-xl mb-3 flex items-center justify-center">
                  <i class="fas fa-gavel text-white text-3xl"></i>
                </div>
                <p class="font-bold text-sm text-gray-900">Hukum & Hak</p>
                <p class="text-xs text-gray-500 mt-1">256+ judul buku</p>
              </div>
              <div class="bg-white rounded-2xl p-5 shadow-xl shadow-violet-500/10 border border-violet-50 transform -rotate-1 hover:rotate-0 transition-transform cursor-pointer">
                <div class="h-24 bg-gradient-to-br from-violet-500 to-purple-500 rounded-xl mb-3 flex items-center justify-center">
                  <i class="fas fa-rocket text-white text-3xl"></i>
                </div>
                <p class="font-bold text-sm text-gray-900">Wirausaha</p>
                <p class="text-xs text-gray-500 mt-1">302+ judul buku</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-gray-400 animate-bounce">
      <span class="text-xs font-medium">Scroll</span>
      <i class="fas fa-chevron-down text-sm"></i>
    </div>
  </section>

  <!-- STATS -->
  <section class="py-16 bg-white border-y border-gray-100">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {stats.map((stat) => (
          <div class="text-center p-6 rounded-2xl bg-warm-50 border border-orange-100/50 hover:shadow-lg hover:-translate-y-0.5 transition-all">
            <div class="w-12 h-12 bg-gradient-to-br from-orange-500 to-green-600 rounded-xl flex items-center justify-center mx-auto mb-3 shadow-md">
              <i class={`fas ${stat.icon} text-white`}></i>
            </div>
            <div class="text-3xl font-extrabold bg-gradient-to-r from-orange-500 to-green-500 bg-clip-text text-transparent mb-1">{stat.value}</div>
            <div class="text-sm text-gray-500 font-medium">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED BOOKS -->
  <section class="py-24 bg-warm-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-12">
        <div>
          <span class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-orange-100 text-orange-700 rounded-full text-sm font-semibold mb-3">
            <i class="fas fa-star"></i> Pilihan Editor
          </span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900">
            Buku Pilihan <span class="bg-gradient-to-r from-orange-500 to-green-500 bg-clip-text text-transparent">untuk Anda</span>
          </h2>
          <p class="text-gray-500 mt-2">Koleksi kurasi terbaik untuk perjalanan Anda.</p>
        </div>
        <a href="/katalog" class="inline-flex items-center gap-2 px-6 py-3 border-2 border-gray-200 text-gray-700 font-semibold rounded-full hover:border-orange-300 hover:bg-orange-50 transition-all flex-shrink-0">
          Lihat Semua <i class="fas fa-arrow-right"></i>
        </a>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
        {featuredBooks.map((book) => (
          <div class="bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col">
            <div class={`h-44 bg-gradient-to-br ${book.colorFrom} ${book.colorTo} flex items-center justify-center p-4 relative flex-shrink-0`}>
              <div class="text-center">
                <i class="fas fa-book text-white/80 text-4xl mb-2 block"></i>
                <p class="text-white/80 text-xs font-medium text-center leading-tight">{book.title}</p>
              </div>
              <span class="absolute top-3 left-3 px-2.5 py-1 bg-white/90 backdrop-blur rounded-full text-xs font-semibold text-gray-700">
                {book.category}
              </span>
            </div>
            <div class="p-4 flex flex-col flex-1">
              <h3 class="font-bold text-gray-900 text-sm leading-snug mb-1 line-clamp-2">{book.title}</h3>
              <p class="text-gray-500 text-xs mb-0.5">{book.author}</p>
              <p class="text-xs text-gray-400 mb-3">{book.year}</p>
              <div class="mt-auto flex items-center justify-between pt-3 border-t border-gray-100">
                <span class="text-xs text-gray-400"><i class="fas fa-file-lines mr-1"></i>{book.pages} halaman</span>
                <a href="/katalog" class="px-3 py-1.5 bg-orange-600 text-white text-xs font-semibold rounded-full hover:bg-orange-700 transition-colors">
                  <i class="fas fa-book-reader mr-1"></i>Baca
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-green-100 text-green-700 rounded-full text-sm font-semibold mb-4">
          <i class="fas fa-play-circle"></i> Cara Kerja
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">
          Tiga Langkah Mudah<br>
          <span class="bg-gradient-to-r from-orange-500 to-green-500 bg-clip-text text-transparent">Memulai Perjalanan Baru</span>
        </h2>
        <p class="text-gray-500 max-w-xl mx-auto">Tidak perlu biaya, tidak perlu mendaftar. Cukup cari dan mulai membaca.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 relative">
        <div class="hidden md:block absolute top-20 left-1/4 right-1/4 h-0.5 bg-gradient-to-r from-orange-300 via-green-300 to-blue-300 rounded-full -z-10"></div>
        {steps.map((step) => (
          <div class="text-center group">
            <div class="w-16 h-16 bg-gradient-to-br from-orange-500 to-green-600 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg group-hover:scale-110 transition-transform">
              <i class={`fas ${step.icon} text-white text-xl`}></i>
            </div>
            <div class="text-5xl font-extrabold text-orange-100 mb-3 select-none">{step.num}</div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">{step.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed max-w-xs mx-auto">{step.desc}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-14">
        <a href="/katalog" class="inline-flex items-center gap-2 px-10 py-4 bg-gradient-to-r from-orange-500 to-green-600 text-white font-bold rounded-full hover:shadow-xl hover:shadow-orange-500/25 transition-all hover:-translate-y-0.5 text-base">
          <i class="fas fa-rocket"></i>
          Mulai Sekarang - Gratis!
        </a>
      </div>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="py-24 bg-warm-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <span class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-amber-100 text-amber-700 rounded-full text-sm font-semibold mb-4">
          <i class="fas fa-th-large"></i> Kategori
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">
          Jelajahi berdasarkan <span class="bg-gradient-to-r from-orange-500 to-green-500 bg-clip-text text-transparent">Topik</span>
        </h2>
        <p class="text-gray-500 max-w-lg mx-auto">Temukan pengetahuan yang Anda butuhkan untuk membangun kehidupan baru.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-5">
        {categories.map((cat) => (
          <a href={cat.href} class="flex items-center gap-4 p-5 bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
            <div class={`w-12 h-12 ${cat.color} rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform`}>
              <i class={`fas ${cat.icon}`}></i>
            </div>
            <div>
              <p class="font-bold text-gray-900 text-sm group-hover:text-orange-700 transition-colors">{cat.name}</p>
              <p class="text-xs text-gray-400 mt-0.5">{cat.count} judul</p>
            </div>
            <i class="fas fa-arrow-right text-gray-300 ml-auto group-hover:translate-x-1 group-hover:text-orange-500 transition-all"></i>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- MISSION -->
  <section class="py-24 bg-gray-900 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-orange-500 rounded-full blur-3xl translate-x-1/3 -translate-y-1/3"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-green-500 rounded-full blur-3xl -translate-x-1/3 translate-y-1/3"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-orange-500/20 text-orange-300 rounded-full text-sm font-semibold mb-5">
            <i class="fas fa-seedling"></i> Misi Kami
          </span>
          <h2 class="text-3xl md:text-4xl font-extrabold mb-6 leading-tight">
            Pengetahuan adalah<br><span class="text-orange-400">kunci pembuka pintu</span>
          </h2>
          <p class="text-gray-400 leading-relaxed mb-8">
            Kami percaya bahwa setiap orang berhak mendapatkan kesempatan kedua. Buka Pintu lahir dari kesadaran bahwa mantan narapidana sering kali menghadapi hambatan besar dalam mengakses pendidikan dan keterampilan - padahal inilah yang paling mereka butuhkan untuk memulai ulang.
          </p>
          <div class="space-y-3 mb-8">
            <div class="flex items-center gap-3">
              <i class="fas fa-check-circle text-green-400"></i>
              <span class="text-gray-300 text-sm">Akses 100% gratis ke ribuan koleksi buku</span>
            </div>
            <div class="flex items-center gap-3">
              <i class="fas fa-check-circle text-green-400"></i>
              <span class="text-gray-300 text-sm">Berbasis komunitas - siapa pun bisa berkontribusi</span>
            </div>
            <div class="flex items-center gap-3">
              <i class="fas fa-check-circle text-green-400"></i>
              <span class="text-gray-300 text-sm">Dirancang untuk pengguna dengan keterbatasan akses internet</span>
            </div>
          </div>
          <div class="flex gap-4">
            <a href="/katalog" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-orange-500 to-green-600 text-white font-bold rounded-full hover:shadow-xl transition-all hover:-translate-y-0.5">
              <i class="fas fa-book-open"></i> Mulai Membaca
            </a>
            <a href="/sumber-daya" class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 backdrop-blur border border-white/20 text-white font-medium rounded-full hover:bg-white/20 transition-all">
              <i class="fas fa-folder-open"></i> Sumber Daya
            </a>
          </div>
        </div>

        <div class="hidden lg:block">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-br from-orange-500/10 to-green-500/10 rounded-3xl blur-xl"></div>
            <div class="relative bg-white/5 backdrop-blur border border-white/10 rounded-3xl p-8 space-y-4">
              <div class="flex items-center gap-3 p-4 bg-white/5 rounded-xl">
                <div class="w-10 h-10 bg-orange-500 rounded-lg flex items-center justify-center flex-shrink-0">
                  <i class="fas fa-door-open text-white"></i>
                </div>
                <div>
                  <p class="font-bold text-white text-sm">Buka Pintu</p>
                  <p class="text-gray-400 text-xs">Perpustakaan Digital</p>
                </div>
              </div>
              <div class="flex items-center gap-3 p-4 bg-white/5 rounded-xl">
                <div class="w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center flex-shrink-0">
                  <i class="fas fa-cog text-white"></i>
                </div>
                <div>
                  <p class="font-bold text-white text-sm">Kelola Koleksi</p>
                  <p class="text-gray-400 text-xs">tambah & edit buku</p>
                </div>
              </div>
              <div class="flex items-center gap-3 p-4 bg-white/5 rounded-xl">
                <div class="w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center flex-shrink-0">
                  <i class="fas fa-graduation-cap text-white"></i>
                </div>
                <div>
                  <p class="font-bold text-white text-sm">Keterampilan</p>
                  <p class="text-gray-400 text-xs">belajar tanpa batas</p>
                </div>
              </div>
              <div class="flex items-center gap-3 p-4 bg-orange-500/20 rounded-xl border border-orange-400/20">
                <div class="w-10 h-10 bg-orange-500 rounded-lg flex items-center justify-center flex-shrink-0">
                  <i class="fas fa-rocket text-white"></i>
                </div>
                <div>
                  <p class="font-bold text-orange-300 text-sm">Mulai Ulang</p>
                  <p class="text-gray-400 text-xs">kesempatan baru menanti</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="py-24 bg-warm-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <span class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-green-100 text-green-700 rounded-full text-sm font-semibold mb-4">
          <i class="fas fa-comments"></i> Kisah Mereka
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">
          Kisah Sukses dari <span class="bg-gradient-to-r from-orange-500 to-green-500 bg-clip-text text-transparent">Komunitas Kami</span>
        </h2>
        <p class="text-gray-500 max-w-lg mx-auto">Dengarkan pengalaman nyata dari pengguna yang telah merasakan manfaat Buka Pintu.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {testimonials.map((t) => (
          <div class="bg-white rounded-2xl p-8 shadow-lg shadow-gray-200/50 border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => <i class="fas fa-star text-amber-400 text-sm"></i>)}
            </div>
            <p class="text-gray-600 leading-relaxed text-sm flex-1 mb-6">"{t.quote}"</p>
            <div class="flex items-center gap-3 pt-4 border-t border-gray-100">
              <div class={`w-11 h-11 bg-gradient-to-br ${t.gradient} rounded-xl flex items-center justify-center text-white font-bold text-sm flex-shrink-0`}>
                {t.initials}
              </div>
              <div>
                <p class="font-bold text-gray-900 text-sm">{t.name}</p>
                <p class="text-xs text-gray-500">{t.role}</p>
                <p class="text-xs text-gray-400"><i class="fas fa-map-marker-alt text-orange-400 mr-1"></i>{t.location}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gradient-to-br from-orange-500 via-orange-400 to-green-600 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 right-0 w-96 h-96 bg-white rounded-full blur-3xl translate-x-1/3 -translate-y-1/3"></div>
      <div class="absolute bottom-0 left-0 w-80 h-80 bg-white rounded-full blur-3xl -translate-x-1/3 translate-y-1/3"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-6 text-center">
      <div class="w-20 h-20 bg-white/20 backdrop-blur rounded-2xl flex items-center justify-center mx-auto mb-8">
        <i class="fas fa-door-open text-white text-3xl"></i>
      </div>
      <h2 class="text-3xl md:text-5xl font-extrabold mb-5 leading-tight">Pintu Kesempatan<br>Sedang Terbuka</h2>
      <p class="text-white/80 text-lg mb-10 max-w-2xl mx-auto">
        Jangan biarkan masa lalu menutup peluang Anda. Mulai jelajahi pengetahuan hari ini dan bangun masa depan yang Anda impikan.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/katalog" class="inline-flex items-center justify-center gap-3 px-10 py-4 bg-white text-orange-700 font-bold rounded-full hover:shadow-2xl hover:-translate-y-1 transition-all text-lg">
          <i class="fas fa-book-open"></i>
          Jelajahi Sekarang
        </a>
        <a href="/admin" class="inline-flex items-center justify-center gap-3 px-10 py-4 bg-white/15 backdrop-blur border border-white/30 text-white font-semibold rounded-full hover:bg-white/25 transition-all">
          <i class="fas fa-cog"></i>
          Panel Admin
        </a>
      </div>
    </div>
  </section>

</Layout>