---
import Layout from '../layouts/Layout.astro';

const team = [
  {
    name: 'Andi Wijaya',
    role: 'Pendiri & Ketua Program',
    bio: 'Mantan narapidana yang now menjadi aktivis pendidikan untuk bekas narapidana. Pendiri Buka Pintu sejak 2023.',
    avatar: 'AW',
    color: 'from-brand-500 to-orange-500',
  },
  {
    name: 'Dr. Maya Suhartini',
    role: 'Penasihat Akademik',
    bio: 'Dosen hukum pidana Universitas Indonesia dengan spesialisasi reintegrasi sosial mantan narapidana.',
    avatar: 'MS',
    color: 'from-emerald-500 to-teal-500',
  },
  {
    name: 'Rizky Pratama',
    role: 'Koordinator Teknologi',
    bio: 'Software engineer yang mengembangkan platform digital untuk akses pendidikan di daerah terpencil.',
    avatar: 'RP',
    color: 'from-blue-500 to-cyan-500',
  },
];

const values = [
  { icon: 'fa-hand-holding-heart', title: 'Inklusivitas', desc: 'Setiap orang berhak mengakses pengetahuan, tanpa memandang latar belakang.' },
  { icon: 'fa-lock-open', title: 'Keterbukaan', desc: 'Semua konten bersifat terbuka dan dapat diakses oleh siapa saja, kapan saja.' },
  { icon: 'fa-users', title: 'Komunitas', desc: 'Kami dibangun oleh komunitas, untuk komunitas — melalui gotong royong dan solidaritas.' },
  { icon: 'fa-seedling', title: 'Pertumbuhan', desc: 'Pengetahuan adalah biji yang tumbuh. Kami hadir sebagai pupuk untuk pertumbuhan Anda.' },
];

const partners = [
  { name: 'Open Library', type: 'Partner Data', icon: 'fa-book' },
  { name: 'Internet Archive', type: 'Partner Hosting', icon: 'fa-archive' },
  { name: 'Kementerian Hukum', type: 'Mitra Resmi', icon: 'fa-landmark' },
  { name: 'Komunitas Sobat Berbagi', type: 'Mitra Komunitas', icon: 'fa-hands-helping' },
];
---

<Layout title="Tentang Kami" description="Kenali kisah di balik Buka Pintu — perpustakaan digital gratis untuk mantan narapidana Indonesia.">

  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white py-28 overflow-hidden">
    <div class="absolute inset-0 opacity-15">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-brand-500 rounded-full blur-3xl translate-x-1/3 -translate-y-1/3"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-forest-500 rounded-full blur-3xl -translate-x-1/3 translate-y-1/3"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-6 text-center">
      <div class="w-24 h-24 bg-gradient-to-br from-brand-500 to-forest-500 rounded-3xl flex items-center justify-center mx-auto mb-8 shadow-2xl shadow-brand-500/30">
        <i class="fas fa-door-open text-white text-4xl"></i>
      </div>
      <h1 class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight">
        Buka Pintu<br/><span class="text-brand-400">Buka Kesempatan</span>
      </h1>
      <p class="text-gray-400 text-lg md:text-xl max-w-3xl mx-auto leading-relaxed">
        Kami percaya bahwa mantan narapidana berhak mendapatkan kesempatan kedua untuk membangun kehidupan yang bermartabat — dimulai dari akses terhadap pengetahuan.
      </p>
    </div>
  </section>

  <!-- Our Story -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="tag bg-brand-100 text-brand-700 mb-4">📖 Kisah Kami</span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-6 leading-tight">
            Dari Penjara,<br/><span class="gradient-text">Menuju Perpustakaan</span>
          </h2>
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p>
              Buka Pintu lahir pada tahun 2023 dari keprihatinan terhadap terbatasnya akses pendidikan bagi mantan narapidana di Indonesia. Banyak dari mereka yang memiliki keinginan kuat untuk berubah dan belajar, namun tidak memiliki sumber daya untuk melakukannya.
            </p>
            <p>
              Pendiri kami, yang himself pernah merasakan masa tahanan, memahami secara langsung betapa sulitnya mendapatkan buku dan materi pembelajaran di dalam penjara maupun setelah bebas. Pengetahuan tentang hak-hak hukum, keterampilan kerja, dan pengembangan diri sangat sulit diakses.
            </p>
            <p>
              Dari situlah muncul ide untuk membangun <strong class="text-gray-900">perpustakaan digital gratis</strong> yang bisa diakses siapa saja, kapan saja — tanpa biaya, tanpa batasan, tanpa stigma.
            </p>
          </div>
        </div>
        <div class="relative">
          <div class="bg-gradient-to-br from-brand-50 to-forest-50 rounded-3xl p-10 space-y-6">
            <div class="flex items-center gap-4 bg-white rounded-2xl p-5 shadow-sm">
              <div class="w-14 h-14 bg-brand-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <i class="fas fa-calendar-check text-brand-600 text-2xl"></i>
              </div>
              <div>
                <p class="font-bold text-gray-900">2023</p>
                <p class="text-sm text-gray-500">Buka Pintu didirikan</p>
              </div>
            </div>
            <div class="flex items-center gap-4 bg-white rounded-2xl p-5 shadow-sm">
              <div class="w-14 h-14 bg-forest-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <i class="fas fa-book-open text-forest-600 text-2xl"></i>
              </div>
              <div>
                <p class="font-bold text-gray-900">2.500+ Buku</p>
                <p class="text-sm text-gray-500">Tersedia di katalog</p>
              </div>
            </div>
            <div class="flex items-center gap-4 bg-white rounded-2xl p-5 shadow-sm">
              <div class="w-14 h-14 bg-sky-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <i class="fas fa-users text-sky-600 text-2xl"></i>
              </div>
              <div>
                <p class="font-bold text-gray-900">1.200+ Pengguna</p>
                <p class="text-sm text-gray-500">Aktif membaca setiap bulan</p>
              </div>
            </div>
            <div class="flex items-center gap-4 bg-brand-50 rounded-2xl p-5 border-2 border-brand-200">
              <div class="w-14 h-14 bg-brand-500 rounded-xl flex items-center justify-center flex-shrink-0">
                <i class="fas fa-heart text-white text-2xl"></i>
              </div>
              <div>
                <p class="font-bold text-brand-700">100% Gratis</p>
                <p class="text-sm text-brand-500">Tanpa biaya tersembunyi</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-24 bg-warm-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <span class="tag bg-forest-100 text-forest-700 mb-4">💡 Nilai-Nilai Kami</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900">
          Prinsip yang <span class="gradient-text">Kami Pegang</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {values.map((v) => (
          <div class="bg-white rounded-2xl p-7 border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all">
            <div class="w-14 h-14 bg-gradient-to-br from-brand-500 to-forest-500 rounded-2xl flex items-center justify-center mb-5">
              <i class={`fas ${v.icon} text-white text-xl`}></i>
            </div>
            <h3 class="font-bold text-gray-900 text-lg mb-2">{v.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <span class="tag bg-brand-100 text-brand-700 mb-4">👥 Tim Kami</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900">
          Orang-Orang di <span class="gradient-text">Balik Buka Pintu</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {team.map((t) => (
          <div class="text-center group">
            <div class={`w-28 h-28 bg-gradient-to-br ${t.color} rounded-3xl flex items-center justify-center mx-auto mb-5 shadow-lg group-hover:scale-105 transition-transform`}>
              <span class="text-white font-extrabold text-3xl">{t.avatar}</span>
            </div>
            <h3 class="font-bold text-gray-900 text-lg">{t.name}</h3>
            <p class="text-brand-600 text-sm font-semibold mb-3">{t.role}</p>
            <p class="text-gray-500 text-sm leading-relaxed max-w-xs mx-auto">{t.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Partners -->
  <section class="py-24 bg-gray-900 text-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <span class="tag bg-brand-500/20 text-brand-300 mb-4">🤝 Mitra & Partner</span>
        <h2 class="text-3xl md:text-4xl font-extrabold">
          Didukung oleh <span class="text-brand-400">Komunitas</span>
        </h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
        {partners.map((p) => (
          <div class="bg-white/5 border border-white/10 rounded-2xl p-6 text-center hover:bg-white/10 transition-all">
            <div class="w-14 h-14 bg-brand-500/20 rounded-xl flex items-center justify-center mx-auto mb-4">
              <i class={`fas ${p.icon} text-brand-400 text-2xl`}></i>
            </div>
            <p class="font-bold text-white text-sm">{p.name}</p>
            <p class="text-gray-500 text-xs mt-1">{p.type}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>